# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Block direct web access to config files
<FilesMatch "^config\.(php|local\.php|local\.php\.example)$">
    Require all denied
</FilesMatch>

RewriteEngine On

# HTTP -> HTTPS
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://hundekuchenlive.de%{REQUEST_URI} [R=301,L]

# www -> non-www
RewriteCond %{HTTP_HOST} ^www\.hundekuchenlive\.de$ [NC]
RewriteRule ^ https://hundekuchenlive.de%{REQUEST_URI} [R=301,L]

# /index.html -> /
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# /about/index.html -> /about/
RewriteCond %{THE_REQUEST} \s/+(.*?/)?index\.html[\s?] [NC]
RewriteRule ^(.*/)?index\.html$ /$1 [R=301,L]

# Trailing slash für echte Ordner
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.+[^/])$ $1/ [R=301,L]